#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<EOF
Usage: ${0##*/} LIB_NAME [OUT_FILE]

Examples:
  ${0##*/} BondAtoms
  ${0##*/} AppletTempTsSim vite.config.ts
EOF
}

if [[ $# -lt 1 || $# -gt 2 ]]; then
  usage >&2
  exit 1
fi

lib_name="$1"
out_file="${2:-vite.config.ts}"

template_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
template_file="$template_dir/templates/vite.config.ts.template"

if [[ ! -f "$template_file" ]]; then
  echo "ERROR: template not found: $template_file" >&2
  exit 1
fi

sed "s/__LIB_NAME__/${lib_name}/g" "$template_file" > "$out_file"

echo "Generated $out_file with lib name: $lib_name"